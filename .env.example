# Copy this file to .env and fill in values
# For local dev without Docker, set MONGO_URI and REDIS_URL to localhost

PORT=3000
NODE_ENV=development

# MongoDB — use mongo:27017 with Docker Compose, localhost:27017 without
MONGO_URI=mongodb://mongo:27017/drawspace

# Redis — use redis:6379 with Docker Compose, localhost:6379 without
REDIS_URL=redis://redis:6379

# Session secret — change this to a long random string in production
SESSION_SECRET=change_me_to_something_random_and_long
